Q6. Even or Odd Function

def check_even_odd(n):
    if n % 2 == 0:
        return "Even"
    else:
        return "Odd"

num = int(input("Enter a number: "))
print(check_even_odd(num))

Q7. Factorial Function

def factorial(n):
    result = 1
    for i in range(1, n + 1):
        result *= i
    return result

num = int(input("Enter a number: "))
print("Factorial:", factorial(num))

Q8. Largest of Three Numbers

def largest(a, b, c):
